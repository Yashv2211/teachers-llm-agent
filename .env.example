# InstantDB
EXPO_PUBLIC_INSTANT_APP_ID=your_instant_app_id
INSTANT_APP_ADMIN_TOKEN=your_instant_admin_token

# Google OAuth (for teacher sign-in)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Groq (baked into client bundle — used for LLM and Whisper STT)
EXPO_PUBLIC_GROQ_API_KEY=gsk_your_groq_api_key

# Google Text-to-Speech
EXPO_PUBLIC_GOOGLE_TTS_KEY=your_google_tts_api_key

# Note: EXPO_PUBLIC_* vars are baked into the client bundle at build time.
